<li class="playerCardContent" 
    data-userid="<%= player._id %>"
    data-platform="<%= player.platform || '' %>" 
    data-playstyle="<%= player.playstyle || '' %>" 
    data-language="<%= player.language || '' %>">

    <% if (player.friendStatus === 'friends') { %>
      <button class="friend-btn btn-disabled" disabled>Friends</button>
    <% } else if (player.friendStatus === 'pending') { %>
      <button class="friend-btn btn-disabled" disabled>Request sent</button>
    <% } else { %>
      <button class="friend-btn btn-add-friend" data-userid="<%= player._id %>">Add Friend</button>
    <% } %>

    <!-- thumbnail -->

    <div>
        <% if (player.thumbnail) { %>
            <img src="/uploads/<%= player.thumbnail %>" alt="">
        <% } else { %>
            <img src="/images/default-thumbnail.png" alt="default thumbnail">
        <% } %>
    </div>

    <!-- avatar -->

    <img
        src="<%= player.avatar ? '/uploads/' + player.avatar : '/images/player-placeholder.png' %>"
        alt="Profielfoto van <%= player.username %>"
    >

    <!-- user information -->

    <div>
        <h3 class="name"><%= player.username %></h3>
        <p class="bio"><%= player.bio || 'No bio available' %></p>
    </div>

    <!-- platform, playstyle, language apart gerenderd in p -->

    <div>
        <% if (player.platform) { %>
        <% (Array.isArray(player.platform) ? player.platform : player.platform.split(',')).forEach(item => { %>
        <p class="platform"><%= item.trim() %></p>
        <% }) %>
    <% } else { %>
        <p class="platform">No platform</p>
    <% } %>

    <% if (player.playstyle) { %>
        <% (Array.isArray(player.playstyle) ? player.playstyle : player.playstyle.split(',')).forEach(item => { %>
        <p class="playstyle"><%= item.trim() %></p>
        <% }) %>
    <% } else { %>
        <p class="playstyle">No playstyle</p>
    <% } %>

    <% if (player.language) { %>
        <% (Array.isArray(player.language) ? player.language : player.language.split(',')).forEach(item => { %>
        <p class="language"><%= item.trim() %></p>
        <% }) %>
    <% } else { %>
        <p class="language">No language</p>
    <% } %>

    </div>

    <!-- favorite games -->
    <div>       
        <% if (player.favoriteGames && player.favoriteGames.length) { %>
            <ul class="games">
                <% player.favoriteGames.forEach(game => { %>
                    <li><%= game.name %></li>
                <% }) %>
            </ul>
        <% } else { %>
            <p class="games">No favorite games added</p>
        <% } %>
    </div>
    
</li>
