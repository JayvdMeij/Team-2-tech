<form action="/register" method="POST" enctype="multipart/form-data" id="registerForm">
    <input type="text" name="username" placeholder="Username" required />
    <input type="email" name="email" placeholder="Email" required />
    <input type="password" name="password" placeholder="Password" required />

    <label id="avatarLabel" for="avatar">Upload Avatar</label>
    <input type="file" name="avatar" id="avatar" accept="image/*" />

    <div id="avatarPreviewWrap">
        <img id="avatarPreview" alt="Avatar preview" />
        <button type="button" id="removeAvatarBtn">Remove</button>
    </div>

    <div id="gameSearchField">
        <input type="text" id="gameSearch" placeholder="Search for games..." autocomplete="off" />
        <div id="searchResults"></div>
    </div>

    <div id="selectedGames"></div>
    <input type="hidden" name="favoriteGames" id="favoriteGamesInput" />

    <button type="submit" class="primary-btn">Create Account</button>
</form>
