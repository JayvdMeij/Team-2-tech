<form action="/register" method="POST" enctype="multipart/form-data" id="registerForm">
    <div id="registerStep1" data-step="1">
        <input type="text" name="username" placeholder="Username" required />
        <input type="email" name="email" placeholder="Email" required />
        <input type="password" name="password" placeholder="Password" required />

        <label id="avatarLabel" for="avatar">Upload Avatar</label>

        <div class="file-upload">
            <input type="file" name="avatar" id="avatar" accept="image/*" />
            <label for="avatar" class="file-upload-btn">Choose file</label>
            <span id="fileName">No file chosen</span>
        </div>

        <div id="avatarPreviewWrap">
            <img id="avatarPreview" alt="Avatar preview" />
            <button type="button" id="removeAvatarBtn">Remove</button>
        </div>

        <div data-actions>
            <button type="button" class="primary-btn" id="nextStepBtn">Next</button>
        </div>
    </div>

    <div id="registerStep2" data-step="2">
        <!-- <p id="registerOptionalText">These details are optional, so you can skip this step for now.</p> -->

        <label for="platform">Platform</label>
        <select id="platform">
            <option value="">Choose a platform</option>
            <option value="pc">PC</option>
            <option value="switch">Switch</option>
            <option value="mobile">Mobile</option>
            <option value="playstation">PlayStation</option>
            <option value="xbox">Xbox</option>
        </select>

        <div id="selectedPlatforms" class="selected-pills"></div>

        <label for="language">Language</label>
        <select id="language">
            <option value="">Choose a language</option>
            <option value="dutch">Dutch</option>
            <option value="english">English</option>
            <option value="spanish">Spanish</option>
            <option value="french">French</option>
            <option value="german">German</option>
            <option value="chinese">Chinese</option>
            <option value="japanese">Japanese</option>
            <option value="korean">Korean</option>
        </select>

        <div id="selectedLanguages" class="selected-pills"></div>

        <label for="playstyle">Playstyle</label>
        <select id="playstyle">
            <option value="">Choose a playstyle</option>
            <option value="casual">Casual</option>
            <option value="competitive">Competitive</option>
        </select>

        <div id="selectedPlaystyles" class="selected-pills"></div>

        <label for="gameSearch">Favorite games</label>
        <div id="gameSearchField">
            <input type="text" id="gameSearch" placeholder="Search for games..." autocomplete="off" />
            <div id="searchResults"></div>
        </div>

        <div id="selectedGames"></div>
        <input type="hidden" name="favoriteGames" id="favoriteGamesInput" />

        <div data-actions>
            <button type="button" id="backStepBtn">Back</button>
            <!-- <button type="submit" id="skipStepBtn">Skip for now</button> -->
            <button type="submit" class="primary-btn">Create Account</button>
        </div>
    </div>
</form>