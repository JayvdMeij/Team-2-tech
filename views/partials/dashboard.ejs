<%- include('../partials/header', { title: 'Dashboard - GameMatch' }) %>

<section class="dashboard-page">
  <div class="container">
    <div>
      <p>Your profile</p>
      <h1>Welcome, <%= user.username %></h1>
      <p>Keep your profile sharp so other players can find the right match faster.</p>
    </div>

    <div class="dashboard-card">
      <div>
        <div>
          <% if (user.thumbnail) { %>
            <img src="/uploads/<%= user.thumbnail %>" alt="Thumbnail" class="profile-thumbnail" />
          <% } else { %>
            <img src="/images/default-thumbnail.png" alt="Default Thumbnail" class="profile-thumbnail placeholder-thumbnail" />
          <% } %>
        </div>

        <div>
          <% if (user.avatar) { %>
            <img src="/uploads/<%= user.avatar %>" alt="Avatar" class="profile-avatar" />
          <% } else { %>
            <img src="/images/default-avatar.png" alt="Default Avatar" class="profile-avatar placeholder-avatar" />
          <% } %>
        </div>
      </div>

      <div>
        <p>Gamer card</p>
        <h2><%= user.username %></h2>
        <p><%= user.status || 'Offline' %></p>
      </div>

      <% if (success) { %>
        <div id="authSuccess"><%= success %></div>
      <% } %>

      <section>
        <h3>Bio</h3>
        <p><%= user.bio || 'No bio added yet.' %></p>
      </section>

      <section>
        <h3>Tags</h3>
        <div class="tag-list">
          <% if (user.language && user.language.length > 0) { %>
            <% user.language.forEach(language => { %>
              <div class="tag-pill">
                <span><%= language %></span>
              </div>
            <% }) %>
          <% } %>
          <% if (user.playstyle && user.playstyle.length > 0) { %>
            <% user.playstyle.forEach(playstyle => { %>
              <div class="tag-pill">
                <span><%= playstyle %></span>
              </div>
            <% }) %>
          <% } %>
          <% if (user.platform && user.platform.length > 0) { %>
            <% user.platform.forEach(platform => { %>
              <div class="tag-pill">
                <span><%= platform %></span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </section>

      <section>
        <h3>Favorite Games</h3>

        <% if (user.favoriteGames && user.favoriteGames.length > 0) { %>
          <ul class="favorite-games-list">
            <% user.favoriteGames.forEach(game => { %>
              <li>
                <% if (game.background_image) { %>
                  <img src="<%= game.background_image %>" alt="<%= game.name %>" />
                <% } %>
                <span><%= game.name %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>No favorite games yet.</p>
        <% } %>
      </section>

      <section>
        <p>
          This page is ready for the next team step, like profiles, matches or chat.
        </p>

        <div class="hero-actions">
          <a href="/dashboard/edit" class="primary-btn">Edit Profile</a>
          <a href="/" class="primary-btn">Back Home</a>
          <form action="/logout" method="POST">
            <button type="submit" class="secondary-btn dashboard-logout-btn">Log Out</button>
          </form>
        </div>
      </section>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
