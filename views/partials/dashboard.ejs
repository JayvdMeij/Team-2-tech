<%- include('../partials/header', { title: 'Dashboard - GameMatch' }) %>

<section class="dashboard-page">
  <div class="container dashboard-card">
    <h1>Welcome, <%= user.username %> 🎮</h1>

    <% if (user.avatar) { %>
      <img src="/uploads/<%= user.avatar %>" alt="Avatar" class="profile-avatar" />
    <% } else { %>
      <div class="profile-avatar placeholder-avatar">No Avatar</div>
    <% } %>

    <p><strong>Email:</strong> <%= user.email %></p>

    <% if (user.favoriteGames && user.favoriteGames.length > 0) { %>
      <div class="dashboard-games">
        <h3>Favorite Games</h3>
        <div class="dashboard-game-list">
          <% user.favoriteGames.forEach((game) => { %>
            <span class="dashboard-game-pill"><%= game.name %></span>
          <% }) %>
        </div>
      </div>
    <% } %>

    <p class="dashboard-text">
      This page is ready for the next team step, like profiles, matches or chat.
    </p>

    <div class="hero-actions">
      <a href="/" class="primary-btn">Back Home</a>
      <form action="/logout" method="POST">
        <button type="submit" class="secondary-btn dashboard-logout-btn">Log Out</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
