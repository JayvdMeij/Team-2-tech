<%- include('../partials/header', { title: 'Dashboard - GameMatch' }) %>

<section class="dashboard-page">
  
  <h1>Welcome, <%= user.username %> 🎮</h1>
  <div class="container dashboard-card">
    
    <div class="profile-header">

    <div class="dashboard-thumbnail">
      <% if (user.thumbnail) { %>
        <img src="/uploads/<%= user.thumbnail %>" alt="Thumbnail" class="profile-thumbnail" />
      <% } else { %>
        <img src="/images/default-thumbnail.png" alt="Default Thumbnail" class="profile-thumbnail placeholder-thumbnail" />
      <% } %>
    </div>
    
    <div class="dashboard-avatar">
    <% if (user.avatar) { %>
      <img src="/uploads/<%= user.avatar %>" alt="Avatar" class="profile-avatar" />
    <% } else { %>
     <img src="/images/default-avatar.png" alt="Default Avatar" class="profile-avatar placeholder-avatar" />
    <% } %>
</div>
</div>

<div class="dashboard-status">
  <h2><%= user.username %></h2>
  <p><%= user.status || 'Offline' %></p>
</div>

    <div class="dashboard-bio">
<label>bio</label>
<p><%= user.bio || 'No Bio' %></p>
</div>

    <div class="dashboard-tags">
<label>Tags</label>
<div class="tag-list">
  <% if (user.language && user.language.length > 0) { %>
    <% user.language.forEach(language => { %>
      <div class="tag-pill">
        <span><%= language %></span>
      </div>
    <% }) %>
  <% } %>
  <% if (user.playstyle && user.playstyle.length > 0) { %>
    <% user.playstyle.forEach(playstyle => { %>
      <div class="tag-pill">
        <span><%= playstyle %></span>
      </div>
    <% }) %>
  <% } %>
  <% if (user.platform && user.platform.length > 0) { %>
    <% user.platform.forEach(platform => { %>
      <div class="tag-pill">
        <span><%= platform %></span>
      </div>
    <% }) %>
  <% } %>
</div>
</div>
    <% if (success) { %>
      <div id="authSuccess"><%= success %></div>
    <% } %> <!--Kan je weghalen als t niet werkt*-->


      <div class="dashboard-games">
    <label>Favorite Games</label>
    <ul>
    <li><%= user.favoriteGames && user.favoriteGames.length > 0 ? user.favoriteGames[0].name : 'No favorite game.' %></li>
    <li><%= user.favoriteGames && user.favoriteGames.length > 1 ? user.favoriteGames[1].name : 'No favorite game.' %></li>
    <li><%= user.favoriteGames && user.favoriteGames.length > 2 ? user.favoriteGames[2].name : 'No favorite game.' %></li>
    <li><%= user.favoriteGames && user.favoriteGames.length > 3 ? user.favoriteGames[3].name : 'No favorite game.' %></li>
    
    </ul>
    
      </div>
    

    <p class="dashboard-text">
      This page is ready for the next team step, like profiles, matches or chat.
    </p>

    <div class="hero-actions">
      <a href="/dashboard/edit" class="primary-btn">Edit Profile</a>
      <a href="/" class="primary-btn">Back Home</a>
      <form action="/logout" method="POST">
        <button type="submit" class="secondary-btn dashboard-logout-btn">Log Out</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
