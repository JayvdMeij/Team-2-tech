<%- include('../partials/header', { title: 'Register - GameMatch' }) %>

<section class="auth-page game-wall-bg">
  <div class="game-wall-overlay"></div>

  <div class="game-wall">
    <div class="wall-row row-left" id="row1"></div>
    <div class="wall-row row-right" id="row2"></div>
    <div class="wall-row row-left" id="row3"></div>
    <div class="wall-row row-right" id="row4"></div>
    <div class="wall-row row-left" id="row5"></div>
    <div class="wall-row row-right" id="row6"></div>
  </div>

  <div class="container auth-wrap">
    <div class="auth-card">
      <h2>Create Account</h2>
      <p class="auth-subtext">Set up your profile and start matching.</p>

      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <form action="/register" method="POST" enctype="multipart/form-data" class="auth-form" id="registerForm">
        <input type="text" name="username" placeholder="Username" required />
        <input type="email" name="email" placeholder="Email" required />
        <input type="password" name="password" placeholder="Password" required />

        <label class="file-label" id="avatarLabel" for="avatar">Upload Avatar</label>
        <input type="file" name="avatar" id="avatar" accept="image/*" />

        <div id="avatarPreviewWrap" class="avatar-preview-wrap">
          <img id="avatarPreview" class="avatar-preview" alt="Avatar preview" />
          <button type="button" id="removeAvatarBtn" class="remove-avatar-btn">Remove</button>
        </div>

        <div class="game-search-wrapper">
          <input type="text" id="gameSearch" placeholder="Search for games..." autocomplete="off" />
          <div id="searchResults" class="search-results"></div>
        </div>

        <div id="selectedGames" class="selected-games"></div>
        <input type="hidden" name="favoriteGames" id="favoriteGamesInput" />

        <button type="submit" class="primary-btn full-btn">Create Account</button>
      </form>

      <p class="switch-text">
        Already have an account?
        <a href="/login">Log In</a>
      </p>
    </div>
  </div>
</section>

<script src="/js/game-wall.js"></script>
<script src="/js/register.js"></script>
<%- include('../partials/footer') %>
