<%- include('../partials/header', { title: 'Reset Password - GameMatch', bodyClass: 'auth-shell' }) %>

<!-- Hoofdsectie voor de wachtwoord reset pagina -->
<section class="auth-page">
  <!-- Overlay voor de game wall -->
  <div class="game-wall-overlay"></div>

  <!-- Game wall container met rijen voor achtergrondafbeeldingen -->
  <div class="game-wall">
    <div id="row1"></div>
    <div id="row2"></div>
    <div id="row3"></div>
    <div id="row4"></div>
    <div id="row5"></div>
    <div id="row6"></div>
  </div>

  <!-- Container voor het formulier -->
  <div class="container">
    <div class="auth-card">
      <h2>Reset Password</h2>
      <p>Choose a new password for your account.</p>

      <!-- Toon foutmelding als er een error is -->
      <% if (error) { %>
        <div id="authError"><%= error %></div>
      <% } %>

      <!-- Toon succesmelding als er een success is -->
      <% if (success) { %>
        <div id="authSuccess"><%= success %></div>
      <% } %>

      <!-- Als de token geldig is, toon het wachtwoord reset formulier -->
      <% if (validToken) { %>
        <form action="/reset-password/<%= token %>" method="POST" id="loginForm">
          <input type="password" name="password" placeholder="New password" required />
          <button type="submit" class="primary-btn">Save New Password</button>
        </form>
      <% } else { %>
        <!-- Als token ongeldig, toon link om nieuwe reset link aan te vragen -->
        <p>
          <a href="/forgot-password">Request a new reset link</a>
        </p>
      <% } %>

      <!-- Link terug naar login -->
      <p>
        Back to
        <a href="/login">Log In</a>
      </p>
    </div>
  </div>
</section>

<!-- Script voor game wall -->
<script src="/js/game-wall.js"></script>
<%- include('../partials/footer') %>
