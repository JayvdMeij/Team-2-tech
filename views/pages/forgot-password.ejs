<%- include('../partials/header', { title: 'Forgot Password - GameMatch', bodyClass: 'auth-shell' }) %>

<section class="auth-page">
  <div class="game-wall-overlay"></div>

  <div class="game-wall">
    <div id="row1"></div>
    <div id="row2"></div>
    <div id="row3"></div>
    <div id="row4"></div>
    <div id="row5"></div>
    <div id="row6"></div>
  </div>

  <div class="container">
    <div class="auth-card">
      <h2>Forgot Password</h2>
      <p>Enter your email to reset your password.</p>

      <% if (error) { %>
        <div id="authError"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div id="authSuccess"><%= success %></div>
      <% } %>

      <form action="/forgot-password" method="POST" id="loginForm">
        <input type="email" name="email" placeholder="Email" required />
        <button type="submit" class="primary-btn">Send Reset Link</button>
      </form>

      <% if (resetLink) { %>
        <div id="resetLinkBox">
          <p>Temporary dev link:</p>
          <a href="<%= resetLink %>"><%= resetLink %></a>
        </div>
      <% } %>

      <p>
        Remembered your password?<br>
        <a href="/login">Back to Log In</a>
      </p>
    </div>
  </div>
</section>

<script src="/js/game-wall.js"></script>
<%- include('../partials/footer') %>
