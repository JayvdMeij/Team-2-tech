<%- include('../partials/header', { title: 'Forgot Password - GameMatch', bodyClass: 'auth-shell' }) %>

<!-- Hoofdsectie voor de wachtwoord vergeten pagina -->
<section class="auth-page">
  <!-- Overlay voor de game wall -->
  <div class="game-wall-overlay"></div>

  <!-- Game wall container met rijen voor achtergrondafbeeldingen -->
  <div class="game-wall">
    <div id="row1"></div>
    <div id="row2"></div>
    <div id="row3"></div>
    <div id="row4"></div>
    <div id="row5"></div>
    <div id="row6"></div>
  </div>

  <!-- Container voor het formulier -->
  <div class="container">
    <div class="auth-card">
      <h2>Forgot Password</h2>
      <p>Enter your email to reset your password.</p>

      <!-- Toon foutmelding als er een error is -->
      <% if (error) { %>
        <div id="authError"><%= error %></div>
      <% } %>

      <!-- Toon succesmelding als er een success is -->
      <% if (success) { %>
        <div id="authSuccess"><%= success %></div>
      <% } %>

      <!-- Formulier voor het invoeren van email om reset link te verzenden -->
      <form action="/forgot-password" method="POST" id="loginForm">
        <input type="email" name="email" placeholder="Email" required />
        <button type="submit" class="primary-btn">Send Reset Link</button>
      </form>

      <!-- Toon de reset link als deze beschikbaar is -->
      <% if (resetLink) { %>
        <div id="resetLinkBox">
          <p>Temporary reset link:</p>
          <a href="<%= resetLink %>"><%= resetLink %></a>
        </div>
      <% } %>

      <!-- Link terug naar login -->
      <p>
        Remembered your password?<br>
        <a href="/login">Back to Log In</a>
      </p>
    </div>
  </div>
</section>

<!-- Script voor game wall -->
<script src="/js/game-wall.js"></script>
<%- include('../partials/footer') %>
