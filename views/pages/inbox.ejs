<%- include('../partials/header') %>

<section class="inbox-container">
  <h1 class="inbox-title">Inbox</h1>

  <% if (pendingRequests.length === 0) { %>
    <p class="empty-inbox">No pending friend requests.</p>
  <% } else { %>
    <% pendingRequests.forEach(request => { %>
      <div class="request-card" id="request-<%= request.from %>">
        <img
          class="request-avatar"
          src="<%= request.fromAvatar ? '/uploads/' + request.fromAvatar : '/images/default-avatar.png' %>"
          alt="avatar"
        />
        <div class="request-info">
          <div class="request-username"><%= request.fromUsername %></div>
          <div class="request-date">
            <%= new Date(request.createdAt).toLocaleDateString('nl-NL', {
              day: 'numeric', month: 'long', year: 'numeric'
            }) %>
          </div>
        </div>
        <div class="request-actions">
          <button class="btn-accept" onclick="acceptRequest('<%= request.from %>')">
            Accepteren
          </button>
          <button class="btn-decline" onclick="declineRequest('<%= request.from %>')">
            Weigeren
          </button>
        </div>
      </div>
    <% }) %>
  <% } %>
</section>

<script src="/js/inbox.js"></script>

<%- include('../partials/footer') %>
