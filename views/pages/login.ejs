<%- include('../partials/header', { title: 'Login - GameMatch', bodyClass: 'auth-shell' }) %>

<section class="auth-page">
  <div></div>

  <div>
    <div></div>
    <div></div>
    <div></div>
    <div></div>
    <div></div>
    <div></div>
  </div>

  <div>
    <div class="auth-card">
      <h2>Log In</h2>
      <p>Welcome back. Log in to continue.</p>

      <% if (error) { %>
        <div id="authError"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div id="authSuccess"><%= success %></div>
      <% } %>

      <%- include('../partials/log-form') %>

      <p>
        Don't have an account?
        <a href="/register">Sign Up</a>
      </p>
    </div>
  </div>
</section>

<script src="/js/game-wall.js"></script>
<script src="/js/login.js"></script>
<%- include('../partials/footer') %>