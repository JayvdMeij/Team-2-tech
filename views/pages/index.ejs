<%- include("../partials/header", { title: "Home - GameMatch" }) %>

<section class="hero">
  <div class="hero-overlay"></div>

  <div class="container hero-content">
    <h1>Find Gamers That<br>Match Your Playstyle</h1>

    <p>
      Find players who play the same games, on the same platform,
      at the same time as you. No random teammates. Just better matches.
    </p>

    <div class="hero-actions">
      <% if (currentUser) { %>
        <a href="/dashboard" class="primary-btn">Go to dashboard</a>
      <% } else { %>
        <a href="/login" class="primary-btn">Log In</a>
        <a href="/register" class="secondary-btn">Sign Up</a>
      <% } %>
    </div>
  </div>
</section>

<%- include("../partials/footer") %>